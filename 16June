//Reverse Integer
class Solution {
    public int reverse(int x) {
        boolean isNeg=false;
        if(x<0) {
            isNeg=true;
            x=-(x);
        }

        int temp=0;
        temp=x;
        int reverse=0;
        while(temp!=0){
            int digit=temp % 10;
            if(reverse>(Integer.MAX_VALUE-digit)/10) return 0;
            reverse=reverse*10 + digit;
            temp=temp/10;
        }
        if(isNeg) return -reverse;
        return reverse;
    }
}
